{
  "name": "@ealforque/axios-http-logger",
  "version": "1.0.0",
  "description": "Logs every Axios HTTP Error automatically.",
  "author": "Eric Alforque <eric.alforque@gmail.com>",
  "main": "dist/axios_http_logger.service.js",
  "types": "dist/axios_http_logger.service.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "jest --clearCache && jest --coverage --detectOpenHandles",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ealforque/axios-http-logger.git"
  },
  "bugs": {
    "url": "https://github.com/ealforque/axios-http-logger/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "axios",
    "logger",
    "http",
    "interceptor",
    "logging"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "peerDependencies": {
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "http-status-codes": "2.3.0",
    "jest": "30.2.0",
    "prettier": "3.8.1",
    "sequelize-cli": "6.6.5",
    "supertest": "7.2.2",
    "@swc/jest": "0.2.39",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
