{
  "name": "@ealforque/axios-http-logger",
  "version": "1.0.4",
  "description": "Logs every Axios HTTP Error automatically.",
  "author": "Eric Alforque <eric.alforque@gmail.com>",
  "main": "dist/axios_http_logger.service.js",
  "types": "dist/axios_http_logger.service.d.ts",
  "files": [
    "dist",
    "README.md",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ealforque/axios-http-logger.git"
  },
  "bugs": {
    "url": "https://github.com/ealforque/axios-http-logger/issues"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "jest --clearCache && jest --coverage --detectOpenHandles",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "axios": ">=1",
    "dotenv": ">=16"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "http-status-codes": "2.3.0",
    "jest": "30.2.0",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "@swc/jest": "0.2.39",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2"
  },
  "license": "MIT",
  "keywords": [
    "axios",
    "logger",
    "http",
    "interceptor",
    "logging"
  ]
}
